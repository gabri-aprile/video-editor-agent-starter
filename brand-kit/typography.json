{
  "_doc": "Sostituisci i font con i tuoi. Scarica i file .woff2 in brand-kit/fonts/. Il sistema font-family riferisce al nome registrato via @font-face nel template Hyperframes.",
  "primary": {
    "family": "Inter",
    "weights": {
      "regular": 400,
      "medium": 500,
      "bold": 700,
      "extrabold": 800,
      "black": 900
    },
    "files": {
      "400": "Inter-Regular.woff2",
      "500": "Inter-Medium.woff2",
      "700": "Inter-Bold.woff2",
      "800": "Inter-ExtraBold.woff2",
      "900": "Inter-Black.woff2"
    }
  },
  "mono": {
    "family": "JetBrains Mono",
    "files": {
      "400": "JetBrainsMono-Regular.woff2",
      "700": "JetBrainsMono-Bold.woff2"
    }
  },
  "scales": {
    "caption": { "size": 90, "weight": 800, "lineHeight": 1.0 },
    "hero": { "size": 160, "weight": 900, "lineHeight": 0.95 },
    "body": { "size": 42, "weight": 500, "lineHeight": 1.3 },
    "label": { "size": 32, "weight": 700, "lineHeight": 1.2 }
  },
  "captionShadow": "0 4px 8px rgba(0,0,0,0.6), 0 2px 4px rgba(0,0,0,0.8), 0 0 2px rgba(0,0,0,1)",
  "highlightGlow": "0 0 20px var(--accent-1), 0 0 40px var(--accent-1)"
}
